  "keyFeatures": [
    "Multi-agent orchestration with DAG-based task dependencies",
    "Copy-on-write worker isolation for safe parallel execution",
    "Tier-based concurrency control (light/standard/heavy tasks)",
    "Git-based merge queue with conflict resolution",
    "Role system with customizable agent behaviors",
    "MCP server for external tool access",
    "Hashline-based content verification for atomic edits",
    "TUI with streaming markdown rendering"
  ],
  "publicApiSurface": [
    "enki - Launch TUI interface",
    "enki mcp - Run as MCP stdio server",
    "enki_task_create - MCP tool to create standalone tasks",
    "enki_execution_create - MCP tool to create multi-step executions with dependencies",
    "enki_status - MCP tool to show task counts by status",
    "enki_task_list - MCP tool to list all tasks",
    "enki_pause - MCP tool to pause executions or steps",
    "enki_cancel - MCP tool to cancel executions or steps",
    "enki_stop_all - MCP tool to stop all running workers",
    "Orchestrator::handle - Core command processor",
    "Scheduler::tick - DAG scheduler tick",
    "AgentManager - ACP session lifecycle manager"
  ]
